# Server
APP_NAME=ai-sales-assistant
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://127.0.0.1:5500","http://localhost:5500"]

# Database
DATABASE_URL=postgresql+asyncpg://sales:sales@postgres:5432/sales
DB_POOL_SIZE=10

# JWT — generate with: openssl rand -hex 32
JWT_SECRET=change_me_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_HOURS=8
REFRESH_TOKEN_TTL_DAYS=30

# LiteLLM / Ollama
LITELLM_BASE_URL=http://litellm:4000
LITELLM_API_KEY=sk-bank-internal-key
LLM_MODEL=ollama/qwen3:8b-q4_K_M
EMBEDDING_MODEL=ollama/bge-m3
LLM_MAX_TOKENS_SUGGESTION=100
LLM_MAX_TOKENS_EXTRACTION=200
LLM_MAX_TOKENS_SUMMARY=400
LLM_TIMEOUT_SECONDS=5

# STT
# Dev (CPU): use tiny for fast startup. Set Kotib/uzbek_stt_v1 after conversion on GPU server.
#   Convert: docker compose exec api python scripts/convert_stt_model.py
#   Then:    WHISPER_MODEL=/app/models/uzbek_stt_v1_ct2
WHISPER_MODEL=tiny
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_BATCH_SIZE_REALTIME=1
WHISPER_BATCH_SIZE_BATCH=16

# Uploads
UPLOAD_DIR=/app/uploads
MAX_PDF_SIZE_MB=50

# RAG
CHUNK_SIZE_TOKENS=500
CHUNK_OVERLAP_TOKENS=50
RAG_FINAL_TOP_K=5
RAG_DENSE_TOP_K=20
RAG_SPARSE_TOP_K=20
BM25_K=10
RRF_K=60
EMBEDDING_DIM=1024

# Rate limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# Extraction
EXTRACTION_WINDOW_SECONDS=60
EXTRACTION_CONFIDENCE_THRESHOLD=0.8

# Compliance
COMPLIANCE_PHRASES_PATH=/app/app/data/compliance_phrases.json
COMPLIANCE_FUZZY_THRESHOLD=85.0

# Sentiment
SENTIMENT_LLM_COOLDOWN_SECONDS=5.0
SENTIMENT_TURNS_WINDOW=3
SENTIMENT_SCORE_THRESHOLD=2

# WebRTC / signaling
STUN_SERVERS=["stun:stun.l.google.com:19302"]
FALLBACK_ENABLED=true
# TURN_SERVER=turn:turn.example.com:3478
# TURN_USER=turnuser
# TURN_PASSWORD=changeme
WEBRTC_AUDIO_CHUNK_SECONDS=1.0

# Admin seed
ADMIN_EMAIL=admin@bank.uz
ADMIN_PASSWORD=changeme
